# Server
HOST=0.0.0.0
PORT=8080
RUST_LOG=info,saju_backend=debug

# Database (Supabase PostgreSQL)
DATABASE_URL=postgres://saju:saju@localhost:5432/saju_dev
DATABASE_MAX_CONNECTIONS=20

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=2592000

# Encryption (AES-256-GCM for PII)
PII_ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# HMAC (cache key derivation)
HMAC_SECRET=change-me-to-a-random-secret

# Anthropic Claude API
CLAUDE_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-opus-4-6-20250219
CLAUDE_MAX_TOKENS_PER_MESSAGE=2000
CLAUDE_MAX_COST_PER_SESSION_USD=2.00

# NanoBanana API (image generation)
NANOBANANA_API_KEY=nb-xxx
NANOBANANA_BASE_URL=https://api.nanobanana.com/v1

# RevenueCat
REVENUECAT_API_KEY=rc-xxx
REVENUECAT_WEBHOOK_SECRET=whsec-xxx

# Social Login
KAKAO_REST_API_KEY=xxx
APPLE_TEAM_ID=xxx
APPLE_KEY_ID=xxx
APPLE_PRIVATE_KEY_PATH=./keys/apple_auth.p8
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://saju.app

# Rate Limiting
FREE_CARD_DAILY_LIMIT=3
