# ==========================================
# 사주 상담 플랫폼 - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ---------- Database (Supabase PostgreSQL) ----------
DATABASE_URL=postgres://saju_user:your_password@db.your-project.supabase.co:5432/postgres
POSTGRES_PASSWORD=local_dev_password

# ---------- Supabase ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Auth / JWT ----------
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRY_SECONDS=3600
REFRESH_TOKEN_EXPIRY_SECONDS=2592000

# ---------- OAuth Providers ----------
KAKAO_CLIENT_ID=your_kakao_app_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=./keys/apple_auth_key.p8
APPLE_BUNDLE_ID=com.yourcompany.saju
GOOGLE_CLIENT_ID=your_google_client_id

# ---------- AI (Anthropic Claude) ----------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------- Payment (RevenueCat) ----------
REVENUECAT_API_KEY=your_revenuecat_api_key
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# ---------- Object Storage (Cloudflare R2) ----------
R2_BUCKET_URL=https://your-bucket.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=saju-images

# ---------- Fly.io Deployment ----------
FLY_API_TOKEN=your_fly_api_token

# ---------- Vercel Deployment ----------
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id

# ---------- Application ----------
RUST_LOG=info,saju_backend=debug
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
